  "training": {
    "monitor_metric": "pairwise_AP",
    "save_dir": "/sc/home/michele.marschner/project/jaguar_project/checkpoints/round_2/Vanessa_split/scientific_backbone/backbone_dinov2_base",
    "experiment_name": "backbone_dinov2_base",
    "epochs": 40,
